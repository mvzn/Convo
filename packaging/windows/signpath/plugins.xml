<?xml version="1.0" encoding="utf-8"?>
<!-- SignPath artifact configuration "plugins": a zip of the bare Convo.vst3 bundle
     (a folder on Windows; the inner .vst3 is a PE/DLL that gets Authenticode-signed).
     Paste into the SignPath project's artifact configuration named "plugins". -->
<artifact-configuration xmlns="http://signpath.io/artifact-configuration/v1">
  <zip-file>
    <pe-file path="**/*.vst3">
      <authenticode-sign/>
    </pe-file>
  </zip-file>
</artifact-configuration>
